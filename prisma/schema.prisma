// VentureAI data model.
// Default datasource is SQLite for zero-config local runs.
// To use Postgres: change provider to "postgresql" and set DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Report {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Intake snapshot
  idea       String
  region     String
  industry   String
  customer   String
  budget     String
  stage      String

  // Top-line results (denormalized for fast history lists)
  score       Int
  verdict     String // "go" | "improve" | "avoid"
  summary     String
  mock        Boolean @default(true)

  // Full report payload (typed as ValidationReport in lib/types.ts)
  payload String // JSON string

  @@index([createdAt])
}
