# ─────────────────────────────────────────────────────────────
# VentureAI environment template — copy to .env and fill in.
# The app runs fully on mock data with NONE of these set.
# Add keys to switch each subsystem from mock → live.
# ─────────────────────────────────────────────────────────────

# Database (required to persist report history).
# Local dev default uses SQLite; for Postgres use a connection string.
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:pass@localhost:5432/ventureai?schema=public"

# LLM provider — used by lib/analysis/llm.ts to generate the report.
# Without it, the deterministic mock report engine is used (clearly labeled).
ANTHROPIC_API_KEY=""
# Optional override; defaults to a current Claude model.
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Real-time web/market data — used by lib/data/web.ts for competitor &
# demand signals. Without it, sourced mock signals are used (labeled).
# Use whichever search provider you prefer; Tavily shown as default.
TAVILY_API_KEY=""

# Toggle: force mock mode even if keys are present (useful for demos).
NEXT_PUBLIC_FORCE_MOCK="false"
